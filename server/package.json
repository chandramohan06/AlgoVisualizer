{
  "name": "@algovisualizer/server",
  "version": "1.0.0",
  "description": "AlgoVisualizer API Server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --env-file=.env src/server.ts",
    "seed:array": "ts-node --transpile-only -r dotenv/config src/scripts/seedArrayModule.ts",
    "seed:dsa": "ts-node --transpile-only -r dotenv/config src/scripts/seedMasterDSA.ts",
    "seed:quiz": "ts-node --transpile-only -r dotenv/config src/scripts/seedQuizData.ts",
    "seed:quiz:force": "ts-node --transpile-only -r dotenv/config src/scripts/seedQuizData.ts --force",
    "build": "tsc -b",
    "test": "ts-node -r dotenv/config src/tests/auth.test.ts",
    "start": "node dist/server.js",
    "lint": "npx oxlint"
  },
  "dependencies": {
    "@algovisualizer/shared": "*",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "nodemailer": "^6.10.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "mongodb-memory-server": "^11.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
